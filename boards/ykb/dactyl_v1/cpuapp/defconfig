# Enable MPU
CONFIG_ARM_MPU=y

# Enable hardware stack protection
CONFIG_HW_STACK_PROTECTION=y

# Enable TrustZone-M
CONFIG_ARM_TRUSTZONE_M=y

# Enable GPIO
CONFIG_GPIO=y

# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable CPUNET
CONFIG_SOC_NRF53_CPUNET_ENABLE=y

# USB Connect library setup
CONFIG_LIB_USB_CONNECT=y
CONFIG_LIB_USB_CONNECT_PID=0x0001
CONFIG_LIB_USB_CONNECT_PRODUCT="Dactyl V1"
CONFIG_LIB_USB_CONNECT_MAX_POWER=250

# BT Connect library setup
CONFIG_LIB_BT_CONNECT=y
CONFIG_BT_MAX_CONN=1
CONFIG_BT_HIDS_MAX_CLIENT_COUNT=1
CONFIG_BT_MAX_PAIRED=2
CONFIG_BT_DEVICE_NAME="Dactyl V1"
CONFIG_BT_DIS_PNP_PID=0x0001
CONFIG_BT_DIS_PNP_VER=0x0001

# Enable Flash as SettingsAPI backend
CONFIG_FLASH=y
CONFIG_NVS=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
